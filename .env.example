# ─────────────────────────────────────────────────────────
#  funding-radar — Environment Variables Example
#  Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────
APP_NAME=funding-radar
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-32char-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── PostgreSQL / TimescaleDB ──────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=funding_user
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=funding_radar
DATABASE_URL=postgresql+asyncpg://funding_user:supersecretpassword@postgres:5432/funding_radar
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redissecretpassword
REDIS_DB=0
REDIS_URL=redis://:redissecretpassword@redis:6379/0
REDIS_MAX_CONNECTIONS=20
CACHE_TTL_SECONDS=30

# ── Auth / JWT ────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-64char-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PRO=price_...

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890     # channel/group for alerts

# ── DEX Integrations ──────────────────────────────────────
# dYdX
DYDX_API_URL=https://api.dydx.exchange
DYDX_WS_URL=wss://api.dydx.exchange/v3/ws

# Hyperliquid
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# GMX (Arbitrum)
GMX_API_URL=https://stats.gmx.io/api

# Drift (Solana)
DRIFT_API_URL=https://drift-historical-data.s3.eu-west-1.amazonaws.com

# ── Scheduler ─────────────────────────────────────────────
SCHEDULER_FUNDING_RATE_INTERVAL_SECONDS=10
SCHEDULER_CACHE_CLEANUP_INTERVAL_MINUTES=60

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json             # json | text
